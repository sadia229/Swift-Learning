
// Difference between Struct VS Class

// create an independent objects

struct Person{
    var name:String
}

var p1 = Person(name:"Sadia")
print(p1.name)

print("Makeing Copy")

var p2 = p1
p2.name = "Afrin"
print(p2.name)


class Persons {
    var name: String
    
    init(name: String) {
        self.name = name
    }
}

var p11 = Persons(name: "John")
var p22 = p11

p22.name = "Mike"

print(p11.name) 
print(p22.name) 
